# ============================================================
# Liquid Protocol — Deployment Environment Variables
# Copy to .env and fill in all values before deploying.
# ============================================================

# ---------- Deployer ----------
DEPLOYER_PRIVATE_KEY=REDACTED 
# Private key for the deploying wallet (no 0x prefix) #
OWNER_ADDRESS=0xebA35cE93835Be2431Ae79C1E170DA75056FCFb6                  
# Owner/admin address for all ownable contracts

# ---------- Verification (Etherscan v2 — single key, chain ID selects network) ----------
ETHERSCAN_API_KEY_1=REDACTED
ETHERSCAN_API_KEY_2=REDACTED
ETHERSCAN_API_KEY_3=REDACTED

# Etherscan API key (https://etherscan.io/myapikey) — works for Base via chain ID 8453

# ---------- RPC ----------
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ---------- Base Mainnet External Contracts ----------
WETH=0x4200000000000000000000000000000000000006
UNISWAP_V4_POOL_MANAGER=0x498581fF718922c3f8e6A244956aF099B2652b2b
UNISWAP_V4_POSITION_MANAGER=0x7C5f5A4bBd8fD63184577525326123B519429bdc
UNISWAP_UNIVERSAL_ROUTER=0x6fF5693b99212Da76ad316178A184AB56D299b43
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
UNISWAP_V3_SWAP_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481

# ---------- Protocol Config ----------
LIQUID_PRESALE_FEE_RECIPIENT=REDACTED           
# Address that receives protocol fees from presales

# ---------- Phase 0 Outputs (fill after running 00_DeployCore) ----------
LIQUID_FACTORY=
LIQUID_FEE_LOCKER=
POOL_EXTENSION_ALLOWLIST=

# ---------- Phase 1 Outputs (fill after running 01_DeployHooks) ----------
LIQUID_HOOK_DYNAMIC_FEE_V2=
LIQUID_HOOK_STATIC_FEE_V2=

# ---------- Phase 2 Outputs (fill after running 02_DeployExtensions) ----------
LIQUID_AIRDROP_V2=
LIQUID_VAULT=
LIQUID_UNIV4_ETH_DEV_BUY=
LIQUID_UNIV3_ETH_DEV_BUY=
LIQUID_PRESALE_ETH_TO_CREATOR=
LIQUID_PRESALE_ALLOWLIST=

# ---------- Phase 3 Outputs (fill after running 03_DeployLpLockerAndMev) ----------
LIQUID_LP_LOCKER_FEE_CONVERSION=
LIQUID_SNIPER_AUCTION_V2=
LIQUID_MEV_DESCENDING_FEES=
LIQUID_SNIPER_UTIL_V2=
